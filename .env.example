# Supabase 연결 정보 — 실제 값을 채운 뒤 이 파일을 .env로 복사해서 사용하세요.
#   cp .env.example .env
# Vercel 등 배포 환경에서는 대시보드의 Environment Variables에 동일한 키로 등록합니다.
#
# publishable(anon) 키는 RLS로 보호되는 공개용 키라 클라이언트에 노출되어도 안전합니다.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key
